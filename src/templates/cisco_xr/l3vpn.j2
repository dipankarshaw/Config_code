router bgp 100
 address-family vpnv4 unicast
 !
 address-family vpnv6 unicast
 !
{% for item in range(1,3) -%}
interface loopback {{item}}
 ipv4 address 162.0.{{item}}.{{id}}/32
 vrf RED{{item}}
 root
!
vrf RED{{item}}
 rd 172.0.0.{{id}}:{{item}}
 address-family ipv4 unicast
 import route-target {{item}}:{{item}}
 export route-target {{item}}:{{item}}
!
 address-family ipv6 unicast
 import route-target {{item}}:{{item}}
 export route-target {{item}}:{{item}}
 root
{% endfor %}
