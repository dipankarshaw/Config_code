set protocols bgp group v4-mesh family inet-vpn unicast
set protocols bgp group v6-mesh family inet6-vpn unicast
{%- for item in range(1,2) %}
set routing-instances RED{{item}} instance-type vrf
set routing-instances RED{{item}} route-distinguisher 172.0.0.{{id}}:{{item}}
set routing-instances RED{{item}} vrf-target target:{{item}}:{{item}}
set routing-instances RED{{item}} interface lo0.{{item}}
set interfaces lo0 unit {{item}} family inet address 162.0.{{item}}.{{id}}/32
{% endfor %}
