{% for item in range(1,4) -%}
vrf instance RED{{item}}
ip routing vrf RED{{item}}
    redistribute connected
!
interface Loopback{{item}}
    ip address 162.0.{{item}}.{{id}}/32
    vrf RED{{item}}
!
router bgp 100
    vrf RED{{item}}
        rd 172.0.0.{{id}}:{{item}}
        route-target import {{item}}:{{item}}
        route-target export {{item}}:{{item}}
        redistribute connected
    !
{% endfor %}
